<?xml version="1.0" encoding="utf-8" ?>
<mdscript name="Blockade" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="md.xsd">
	<!--
		Auto-blockade. Walks every active gate; where the sector-side owner is at
		war with the destination-side owner, dispatches a fleet from the defender's
		nearest shipyard. Race-based macro selection (per DeadAir/Dynamic Universe
		precedent) — no tag search.

		State table: md.$BBVarTable, aliased as $BBVT.
			$Enable               bool
			$ScanIntervalMin      int     (informational; check interval is hard-set on TimerBlockadeScan)
			$MinFleetCapital      int     destroyers per blockade
			$MinFleetEscort       int     frigates per blockade
			$MinFleetFighter      int     fighters per blockade
			$BlockadeDistance     length  passed as Blockade order distance
			$DebugDetailed        bool
			$ActiveBlockades      table[gate → blockadeEntry]
			$ExcludedFactions     list

		blockadeEntry: $Faction, $Gate, $Sector, $Ships, $EstablishedAt, $LastCheckedAt
	-->

	<cues>

		<cue name="Init">
			<conditions>
				<event_game_started/>
			</conditions>
			<actions>
				<set_value name="md.$BBVarTable" exact="table[]"/>
				<signal_cue_instantly cue="VerifyVariables"/>
			</actions>
		</cue>

		<cue name="OnLoad" instantiate="true">
			<conditions>
				<event_game_loaded/>
			</conditions>
			<actions>
				<do_if value="(not md.$BBVarTable?) or (md.$BBVarTable == null)">
					<set_value name="md.$BBVarTable" exact="table[]"/>
				</do_if>
				<signal_cue_instantly cue="VerifyVariables"/>
			</actions>
		</cue>

		<cue name="VerifyVariables" instantiate="true">
			<conditions>
				<event_cue_signalled/>
			</conditions>
			<actions>
				<set_value name="$BBVT" exact="md.$BBVarTable"/>
				<do_if value="not $BBVT.$Enable?">
					<set_value name="$BBVT.$Enable" exact="true"/>
				</do_if>
				<do_if value="not $BBVT.$ScanIntervalMin?">
					<set_value name="$BBVT.$ScanIntervalMin" exact="30"/>
				</do_if>
				<do_if value="not $BBVT.$MinFleetCapital?">
					<set_value name="$BBVT.$MinFleetCapital" exact="1"/>
				</do_if>
				<do_if value="not $BBVT.$MinFleetEscort?">
					<set_value name="$BBVT.$MinFleetEscort" exact="3"/>
				</do_if>
				<do_if value="not $BBVT.$MinFleetFighter?">
					<set_value name="$BBVT.$MinFleetFighter" exact="4"/>
				</do_if>
				<do_if value="not $BBVT.$BlockadeDistance?">
					<set_value name="$BBVT.$BlockadeDistance" exact="6km"/>
				</do_if>
				<do_if value="not $BBVT.$DebugDetailed?">
					<set_value name="$BBVT.$DebugDetailed" exact="false"/>
				</do_if>
				<do_if value="not $BBVT.$NewsEnabled?">
					<set_value name="$BBVT.$NewsEnabled" exact="true"/>
				</do_if>
				<do_if value="(not $BBVT.$ActiveBlockades?) or ($BBVT.$ActiveBlockades == null)">
					<set_value name="$BBVT.$ActiveBlockades" exact="table[]"/>
				</do_if>
				<do_if value="not $BBVT.$ExcludedFactions?">
					<set_value name="$BBVT.$ExcludedFactions" exact="[faction.xenon, faction.khaak, faction.yaki, faction.scaleplate, faction.player, faction.civilian, faction.criminal, faction.smuggler, faction.visitor]"/>
				</do_if>
			</actions>
		</cue>

		<cue name="TimerBlockadeScan" instantiate="true" checkinterval="30min" checktime="2min">
			<conditions>
				<check_value value="md.$BBVarTable.$Enable"/>
			</conditions>
			<actions>
				<signal_cue_instantly cue="EventBlockadeMaintenance"/>
				<signal_cue_instantly cue="EventBlockadeScan"/>
			</actions>
		</cue>

		<cue name="EventBlockadeScan" instantiate="true">
			<conditions>
				<event_cue_signalled/>
			</conditions>
			<actions>
				<set_value name="$BBVT" exact="md.$BBVarTable"/>
				<find_gate name="$BBLocAllGates" space="player.galaxy" active="true" multiple="true"/>
				<do_for_each name="$LocGate" in="$BBLocAllGates">
					<do_if value="$LocGate.exists and $LocGate.destination.exists">
						<set_value name="$Defender" exact="$LocGate.sector.owner"/>
						<set_value name="$Attacker" exact="$LocGate.destination.sector.owner"/>
						<do_if value="$Defender and $Attacker and ($Defender != $Attacker)
						              and ($BBVT.$ExcludedFactions.indexof.{$Defender} == 0)
						              and ($BBVT.$ExcludedFactions.indexof.{$Attacker} == 0)
						              and $Defender.mayattack.{$Attacker}
						              and ($Defender.relationto.{$Attacker} le -0.25)
						              and not $BBVT.$ActiveBlockades.{$LocGate}?">

							<!-- Skip if anyone (player or other faction) is already blockading
							     this gate. Cheap heuristic: any ship in the gate's sector within
							     25km whose current order is 'Blockade'. -->
							<find_ship name="$BBLocSectorShips" space="$LocGate.sector" multiple="true"/>
							<set_value name="$BBLocOccupied" exact="false"/>
							<do_for_each name="$BBLocShip" in="$BBLocSectorShips">
								<do_if value="(@$BBLocShip.order.id == 'Blockade') and ($BBLocShip.distanceto.{$LocGate} lt 25km)">
									<set_value name="$BBLocOccupied" exact="true"/>
									<break/>
								</do_if>
							</do_for_each>

							<do_if value="not $BBLocOccupied">
								<signal_cue_instantly cue="EventDispatchBlockade" param="table[
									$DefenderFaction = $Defender,
									$AttackerFaction = $Attacker,
									$Gate = $LocGate
								]"/>
							</do_if>
						</do_if>
					</do_if>
				</do_for_each>
			</actions>
		</cue>

		<cue name="EventDispatchBlockade" instantiate="true">
			<conditions>
				<event_cue_signalled/>
			</conditions>
			<actions>
				<set_value name="$BBVT" exact="md.$BBVarTable"/>
				<set_value name="$Defender" exact="event.param.$DefenderFaction"/>
				<set_value name="$Gate" exact="event.param.$Gate"/>

				<do_if value="$Gate.exists">
					<find_station_by_true_owner name="$BBLocShipyard" faction="$Defender" space="player.galaxy" canbuildships="true"/>
					<do_if value="$BBLocShipyard">

						<set_value name="$Sector" exact="$Gate.sector"/>
						<set_value name="$Ships" exact="[]"/>

						<!-- Pick race-appropriate macros up front. -->
						<set_value name="$Race" exact="$Defender.primaryrace"/>
						<set_value name="$MacroL" exact="null"/>
						<set_value name="$MacroM" exact="null"/>
						<set_value name="$MacroS" exact="null"/>
						<do_if value="$Race == race.argon">
							<set_value name="$MacroL" exact="macro.ship_arg_l_destroyer_01_a_macro"/>
							<set_value name="$MacroM" exact="macro.ship_arg_m_frigate_01_a_macro"/>
							<set_value name="$MacroS" exact="macro.ship_arg_s_heavyfighter_01_a_macro"/>
						</do_if>
						<do_elseif value="$Race == race.paranid">
							<set_value name="$MacroL" exact="macro.ship_par_l_destroyer_01_a_macro"/>
							<set_value name="$MacroM" exact="macro.ship_par_m_corvette_01_a_macro"/>
							<set_value name="$MacroS" exact="macro.ship_par_s_heavyfighter_01_a_macro"/>
						</do_elseif>
						<do_elseif value="$Race == race.teladi">
							<set_value name="$MacroL" exact="macro.ship_tel_l_destroyer_01_a_macro"/>
							<set_value name="$MacroM" exact="macro.ship_tel_m_frigate_01_a_macro"/>
							<set_value name="$MacroS" exact="macro.ship_tel_s_fighter_01_a_macro"/>
						</do_elseif>
						<do_elseif value="$Race == race.split">
							<set_value name="$MacroL" exact="macro.ship_spl_l_destroyer_01_a_macro"/>
							<set_value name="$MacroM" exact="macro.ship_spl_m_corvette_01_a_macro"/>
							<set_value name="$MacroS" exact="macro.ship_spl_s_heavyfighter_01_a_macro"/>
						</do_elseif>
						<do_elseif value="$Race == race.terran">
							<set_value name="$MacroL" exact="macro.ship_ter_l_destroyer_01_a_macro"/>
							<set_value name="$MacroM" exact="macro.ship_ter_m_corvette_01_a_macro"/>
							<set_value name="$MacroS" exact="macro.ship_ter_s_heavyfighter_01_a_macro"/>
						</do_elseif>
						<do_elseif value="$Race == race.boron">
							<set_value name="$MacroL" exact="macro.ship_bor_l_destroyer_01_a_macro"/>
							<set_value name="$MacroM" exact="macro.ship_bor_m_corvette_01_a_macro"/>
							<set_value name="$MacroS" exact="macro.ship_bor_s_heavyfighter_01_a_macro"/>
						</do_elseif>
						<do_else>
							<set_value name="$MacroL" exact="macro.ship_arg_l_destroyer_01_a_macro"/>
							<set_value name="$MacroM" exact="macro.ship_arg_m_frigate_01_a_macro"/>
							<set_value name="$MacroS" exact="macro.ship_arg_s_heavyfighter_01_a_macro"/>
						</do_else>

						<!-- Wing model (matches the player-led flow): pick a leader,
						     spawn the rest as its subordinates, then give the leader
						     the Blockade order. The leader's init in
						     aiscripts/order.move.blockade.xml sees subordinates.count
						     gt 0 and dispatches MoveWait to each sub at its slot.
						     Same code path as a player-built wing.

						     Leader preference: L destroyer > M frigate > S fighter,
						     gated by which counts are configured > 0. Decrement the
						     remaining-of-that-class counter so we don't overshoot. -->
						<set_value name="$LeaderMacro" exact="null"/>
						<set_value name="$RemainCapital" exact="$BBVT.$MinFleetCapital"/>
						<set_value name="$RemainEscort" exact="$BBVT.$MinFleetEscort"/>
						<set_value name="$RemainFighter" exact="$BBVT.$MinFleetFighter"/>
						<do_if value="$RemainCapital gt 0 and $MacroL != null">
							<set_value name="$LeaderMacro" exact="$MacroL"/>
							<set_value name="$RemainCapital" operation="subtract" exact="1"/>
						</do_if>
						<do_elseif value="$RemainEscort gt 0 and $MacroM != null">
							<set_value name="$LeaderMacro" exact="$MacroM"/>
							<set_value name="$RemainEscort" operation="subtract" exact="1"/>
						</do_elseif>
						<do_elseif value="$RemainFighter gt 0 and $MacroS != null">
							<set_value name="$LeaderMacro" exact="$MacroS"/>
							<set_value name="$RemainFighter" operation="subtract" exact="1"/>
						</do_elseif>

						<do_if value="$LeaderMacro == null">
							<do_if value="$BBVT.$DebugDetailed">
								<debug_text text="'BB: dispatch aborted at %s — no suitable leader macro for race %s with configured counts.'.[$Gate.knownname, $Race]" filter="general"/>
							</do_if>
						</do_if>
						<do_else>
							<!-- Spawn leader first so we have a commander reference. -->
							<create_ship name="$LocLeader" macro="$LeaderMacro" sector="$BBLocShipyard.sector">
								<owner exact="$Defender"/>
								<position object="$BBLocShipyard" max="5km"/>
							</create_ship>

							<do_if value="$LocLeader">
								<append_to_list name="$Ships" exact="$LocLeader"/>

								<!-- Spawn remaining capitals as subordinates. Subgroup
								     1 holds capitals/escorts, 2 holds fighters — keeps
								     the wing display tidy. -->
								<set_value name="$Counter" exact="0"/>
								<do_while value="$Counter lt $RemainCapital">
									<create_ship name="$LocShip" macro="$MacroL" sector="$BBLocShipyard.sector">
										<owner exact="$Defender"/>
										<position object="$BBLocShipyard" max="5km"/>
									</create_ship>
									<do_if value="$LocShip">
										<set_object_commander object="$LocShip" commander="$LocLeader" subordinategroupid="1"/>
										<append_to_list name="$Ships" exact="$LocShip"/>
									</do_if>
									<remove_value name="$LocShip"/>
									<set_value name="$Counter" operation="add" exact="1"/>
								</do_while>

								<!-- Escort frigates / corvettes. Same subgroup 1. -->
								<set_value name="$Counter" exact="0"/>
								<do_while value="$Counter lt $RemainEscort">
									<create_ship name="$LocShip" macro="$MacroM" sector="$BBLocShipyard.sector">
										<owner exact="$Defender"/>
										<position object="$BBLocShipyard" max="5km"/>
									</create_ship>
									<do_if value="$LocShip">
										<set_object_commander object="$LocShip" commander="$LocLeader" subordinategroupid="1"/>
										<append_to_list name="$Ships" exact="$LocShip"/>
									</do_if>
									<remove_value name="$LocShip"/>
									<set_value name="$Counter" operation="add" exact="1"/>
								</do_while>

								<!-- Fighter screen. Subgroup 2 keeps them visually
								     separated from the capitals in the player's
								     properties UI when they look at a friendly wing. -->
								<set_value name="$Counter" exact="0"/>
								<do_while value="$Counter lt $RemainFighter">
									<create_ship name="$LocShip" macro="$MacroS" sector="$BBLocShipyard.sector">
										<owner exact="$Defender"/>
										<position object="$BBLocShipyard" max="5km"/>
									</create_ship>
									<do_if value="$LocShip">
										<set_object_commander object="$LocShip" commander="$LocLeader" subordinategroupid="2"/>
										<append_to_list name="$Ships" exact="$LocShip"/>
									</do_if>
									<remove_value name="$LocShip"/>
									<set_value name="$Counter" operation="add" exact="1"/>
								</do_while>

								<!-- Now (and only now, after all subs are attached) give
								     the leader the Blockade order. Its init enumerates
								     this.assignedcontrolled.subordinates, class-sorts
								     them, and dispatches MoveWait to each with its
								     own slot index. -->
								<create_order id="'Blockade'" object="$LocLeader" default="true">
									<param name="target" value="$Gate"/>
									<param name="distance" value="$BBVT.$BlockadeDistance"/>
								</create_order>
							</do_if>
							<remove_value name="$LocLeader"/>
						</do_else>

						<set_value name="$BBVT.$ActiveBlockades.{$Gate}" exact="table[
							$Faction = $Defender,
							$Gate = $Gate,
							$Sector = $Sector,
							$Ships = $Ships,
							$EstablishedAt = player.age,
							$LastCheckedAt = player.age
						]"/>

						<do_if value="$BBVT.$NewsEnabled and ($Ships.count gt 0)">
							<write_to_logbook category="news"
							                  title="{20810, 100}"
							                  text="{20810, 400}.[$Defender.name, $Gate.knownname, $Sector.knownname]"
							                  faction="$Defender"
							                  object="$Gate"/>
						</do_if>

						<do_if value="$BBVT.$DebugDetailed">
							<debug_text text="'BB: %s established blockade at %s (%s ships).'.[$Defender.name, $Gate.knownname, $Ships.count]" filter="general"/>
						</do_if>

					</do_if>
				</do_if>
			</actions>
		</cue>


		<cue name="EventBlockadeMaintenance" instantiate="true">
			<conditions>
				<event_cue_signalled/>
			</conditions>
			<actions>
				<set_value name="$BBVT" exact="md.$BBVarTable"/>
				<do_for_each name="$LocKey" in="$BBVT.$ActiveBlockades.keys.list">
					<set_value name="$Entry" exact="$BBVT.$ActiveBlockades.{$LocKey}"/>
					<set_value name="$Defender" exact="$Entry.$Faction"/>
					<set_value name="$Gate" exact="$Entry.$Gate"/>

					<set_value name="$ShouldDisband" exact="false"/>
					<do_if value="not $Gate.exists or not $Gate.destination.exists">
						<set_value name="$ShouldDisband" exact="true"/>
					</do_if>
					<do_elseif value="$Gate.destination.sector.owner == $Defender">
						<set_value name="$ShouldDisband" exact="true"/>
					</do_elseif>
					<do_elseif value="$Defender.relationto.{$Gate.destination.sector.owner} gt -0.1">
						<set_value name="$ShouldDisband" exact="true"/>
					</do_elseif>

					<set_value name="$Alive" exact="[]"/>
					<do_for_each name="$LocShip" in="$Entry.$Ships">
						<do_if value="$LocShip.exists and $LocShip.isoperational">
							<append_to_list name="$Alive" exact="$LocShip"/>
						</do_if>
					</do_for_each>
					<set_value name="$Entry.$Ships" exact="$Alive"/>
					<set_value name="$Entry.$LastCheckedAt" exact="player.age"/>

					<do_if value="$Alive.count == 0">
						<set_value name="$ShouldDisband" exact="true"/>
					</do_if>

					<do_if value="$ShouldDisband">
						<do_if value="$BBVT.$NewsEnabled and $Gate.exists">
							<write_to_logbook category="news"
							                  title="{20810, 100}"
							                  text="{20810, 401}.[$Gate.knownname]"
							                  faction="$Defender"
							                  object="$Gate"/>
						</do_if>
						<do_if value="$BBVT.$DebugDetailed">
							<debug_text text="'BB: disbanding blockade at %s.'.[@$Gate.knownname]" filter="general"/>
						</do_if>
						<do_for_each name="$LocShip" in="$Alive">
							<do_if value="@$LocShip.order.id == 'Blockade'">
								<cancel_order order="$LocShip.order"/>
							</do_if>
						</do_for_each>
						<remove_value name="$BBVT.$ActiveBlockades.{$LocKey}"/>
					</do_if>
				</do_for_each>
			</actions>
		</cue>

	</cues>
</mdscript>
