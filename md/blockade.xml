<?xml version="1.0" encoding="utf-8" ?>
<mdscript name="Blockade" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="md.xsd">
	<!--
		AI deployment lives in libraries/jobs.xml now — X4's faction economy
		builds the blockade leader + escorts at its shipyards over real time,
		spawned via the job system rather than create_ship.

		This MD file now only holds the persistent state table for any future
		tunables (NewsEnabled, DebugDetailed). The scan/dispatch/maintenance
		cues that previously spawned fleets directly were removed when the
		jobs-based system replaced them. Legacy save data in $ActiveBlockades
		etc. is harmless — it just sits unused.

		State table: md.$BBVarTable, aliased as $BBVT.
			$NewsEnabled          bool   (reserved; logbook entries not currently fired)
			$DebugDetailed        bool   (reserved)
	-->

	<cues>

		<cue name="Init">
			<conditions>
				<event_game_started/>
			</conditions>
			<actions>
				<set_value name="md.$BBVarTable" exact="table[]"/>
				<signal_cue_instantly cue="VerifyVariables"/>
			</actions>
		</cue>

		<cue name="OnLoad" instantiate="true">
			<conditions>
				<event_game_loaded/>
			</conditions>
			<actions>
				<do_if value="(not md.$BBVarTable?) or (md.$BBVarTable == null)">
					<set_value name="md.$BBVarTable" exact="table[]"/>
				</do_if>
				<signal_cue_instantly cue="VerifyVariables"/>
			</actions>
		</cue>

		<cue name="VerifyVariables" instantiate="true">
			<conditions>
				<event_cue_signalled/>
			</conditions>
			<actions>
				<set_value name="$BBVT" exact="md.$BBVarTable"/>
				<do_if value="not $BBVT.$DebugDetailed?">
					<set_value name="$BBVT.$DebugDetailed" exact="false"/>
				</do_if>
				<do_if value="not $BBVT.$NewsEnabled?">
					<set_value name="$BBVT.$NewsEnabled" exact="true"/>
				</do_if>
			</actions>
		</cue>

		<!-- Coverage audit. Runs on the same 5-min cadence as the orphan
		     reaper. Two passes:

		       1. Walk every blockade leader (jobs blockade_<race>_l) and
		          verify its current state — leader exists, has an active
		          Blockade order, target gate is still hostile-facing. The
		          aiscript-side check already finishes the order on
		          hostility loss, but this MD pass catches drift between
		          ticks and logs each leader's gate + escort count so a
		          coverage map is readable from the log.

		       2. Walk every active hostile-facing gate per major faction
		          and check whether ANY ship with order='Blockade' is
		          within 25 km of it. Gates with no coverage get logged
		          as gaps. Informational only — quota=cluster=1 in
		          jobs.xml is the deployment policy and we don't override
		          it here, but the gap log lets the user / dev see which
		          gates are open versus held.

		     Logs at filter='general'. Per-gate volume tops out at
		     ~30 active major-faction gates galaxy-wide, so this is cheap. -->
		<cue name="TimerBlockadeAudit" instantiate="true" checkinterval="5min" checktime="3min">
			<conditions/>
			<actions>
				<signal_cue_instantly cue="EventBlockadeAudit"/>
			</actions>
		</cue>

		<cue name="EventBlockadeAudit" instantiate="true">
			<conditions>
				<event_cue_signalled/>
			</conditions>
			<actions>
				<set_value name="$BBVT" exact="md.$BBVarTable"/>
				<set_value name="$LocFactions" exact="[faction.argon, faction.paranid, faction.teladi, faction.split, faction.terran, faction.boron]"/>
				<set_value name="$LocLeaderJobIds" exact="['blockade_arg_l', 'blockade_par_l', 'blockade_tel_l', 'blockade_spl_l', 'blockade_ter_l', 'blockade_bor_l']"/>

				<!-- Pass 1: leader audit. -->
				<set_value name="$LocLeaderCount" exact="0"/>
				<do_for_each name="$LocAFaction" in="$LocFactions">
					<find_ship name="$LocAShips" space="player.galaxy" multiple="true" faction="$LocAFaction"/>
					<do_for_each name="$LocASh" in="$LocAShips">
						<do_if value="@$LocASh.job and ($LocLeaderJobIds.indexof.{$LocASh.job.id} gt 0)">
							<set_value name="$LocLeaderCount" exact="$LocLeaderCount + 1"/>
							<set_value name="$LocAOrderId" exact="@$LocASh.order.id"/>
							<set_value name="$LocASubs" exact="if @$LocASh.subordinates then $LocASh.subordinates.count else 0"/>
							<debug_text text="'BB: audit leader %s (%s, %s subs) order=%s sector=%s'.[$LocASh.knownname, $LocAFaction.shortname, $LocASubs, @$LocAOrderId, @$LocASh.sector.knownname]" filter="general"/>
							<!-- Zombie check: leader has no Blockade order AND no Patrol/Idle. The aiscript-side hostility check should finish a stale Blockade and let the faction logic re-task; if we see a leader still holding job blockade_*_l but in some weird stuck state, flag it. -->
							<do_if value="@$LocAOrderId and ($LocAOrderId != 'Blockade')">
								<debug_text text="'BB: audit WARN leader %s job %s but current order is %s.'.[$LocASh.knownname, $LocASh.job.id, $LocAOrderId]" filter="general"/>
							</do_if>
						</do_if>
					</do_for_each>
					<remove_value name="$LocAShips"/>
				</do_for_each>

				<!-- Pass 2: gate coverage. -->
				<set_value name="$LocAGateCount" exact="0"/>
				<set_value name="$LocAGateCovered" exact="0"/>
				<find_gate name="$LocAGates" space="player.galaxy" active="true" multiple="true"/>
				<do_for_each name="$LocAG" in="$LocAGates">
					<do_if value="$LocAG.exists
					              and @$LocAG.destination.exists
					              and @$LocAG.sector.owner
					              and @$LocAG.destination.sector.owner
					              and ($LocFactions.indexof.{$LocAG.sector.owner} gt 0)
					              and ($LocAG.sector.owner != $LocAG.destination.sector.owner)
					              and $LocAG.sector.owner.mayattack.{$LocAG.destination.sector.owner}
					              and ($LocAG.sector.owner.relationto.{$LocAG.destination.sector.owner} le -0.25)">
						<set_value name="$LocAGateCount" exact="$LocAGateCount + 1"/>
						<!-- Is there a Blockade-ordered ship of the defender within 25 km? -->
						<set_value name="$LocAGCov" exact="false"/>
						<find_ship name="$LocAGShips" space="$LocAG.sector" multiple="true" faction="$LocAG.sector.owner"/>
						<do_for_each name="$LocAGSh" in="$LocAGShips">
							<do_if value="(not $LocAGCov) and (@$LocAGSh.order.id == 'Blockade') and ($LocAGSh.distanceto.{$LocAG} lt 25km)">
								<set_value name="$LocAGCov" exact="true"/>
							</do_if>
						</do_for_each>
						<remove_value name="$LocAGShips"/>
						<do_if value="$LocAGCov">
							<set_value name="$LocAGateCovered" exact="$LocAGateCovered + 1"/>
						</do_if>
						<do_else>
							<debug_text text="'BB: audit GAP — %s gate from %s to %s has no blockade coverage.'.[$LocAG.sector.knownname, $LocAG.sector.owner.shortname, $LocAG.destination.sector.owner.shortname]" filter="general"/>
						</do_else>
					</do_if>
				</do_for_each>
				<remove_value name="$LocAGates"/>

				<debug_text text="'BB: audit summary — %s active blockade leader(s), %s of %s hostile-facing gates covered.'.[$LocLeaderCount, $LocAGateCovered, $LocAGateCount]" filter="general"/>

				<remove_value name="$LocFactions"/>
				<remove_value name="$LocLeaderJobIds"/>
			</actions>
		</cue>

		<!-- Orphan reaper. When a blockade leader (job blockade_<race>_l) is
		     destroyed, its M/S escort subordinates (wing="3"/"4" jobs) lose
		     their commander. Vanilla TargetInvalidHandler aborts their
		     Escort order on the dead target, but the default order (also
		     Escort) re-fires against the same dead target — so the ship
		     floats idle in a tight abort/retry loop, not despawned but not
		     useful either.

		     This cue periodically finds those orphans and re-tasks them:

		       1. Same-cluster surviving blockade leader of the same faction:
		          re-attach via set_object_commander + cancel current order.
		          The orphan's default Escort then picks up the new
		          commander and the ship joins the surviving wing.

		       2. Otherwise: MoveWait to nearest faction shipyard. Ship
		          becomes idle but reachable for resupply or future
		          reassignment by vanilla faction logic.

		     Detection is by job id (exact match against the 12 escort job
		     ids we define in libraries/jobs.xml). Cheap because we scope
		     find_ship to one faction at a time. -->
		<cue name="TimerBlockadeReap" instantiate="true" checkinterval="5min" checktime="1min">
			<conditions/>
			<actions>
				<signal_cue_instantly cue="EventBlockadeReap"/>
			</actions>
		</cue>

		<cue name="EventBlockadeReap" instantiate="true">
			<conditions>
				<event_cue_signalled/>
			</conditions>
			<actions>
				<set_value name="$BBVT" exact="md.$BBVarTable"/>
				<set_value name="$LocFactions" exact="[faction.argon, faction.paranid, faction.teladi, faction.split, faction.terran, faction.boron]"/>
				<set_value name="$LocLeaderJobIds" exact="['blockade_arg_l', 'blockade_par_l', 'blockade_tel_l', 'blockade_spl_l', 'blockade_ter_l', 'blockade_bor_l']"/>

				<do_for_each name="$LocFaction" in="$LocFactions">
					<find_ship name="$LocShips" space="player.galaxy" multiple="true" faction="$LocFaction"/>
					<do_for_each name="$LocSh" in="$LocShips">
						<do_if value="@$LocSh.job
						              and (@$LocSh.job.id == 'blockade_arg_esc_m' or @$LocSh.job.id == 'blockade_arg_esc_s'
						                or @$LocSh.job.id == 'blockade_par_esc_m' or @$LocSh.job.id == 'blockade_par_esc_s'
						                or @$LocSh.job.id == 'blockade_tel_esc_m' or @$LocSh.job.id == 'blockade_tel_esc_s'
						                or @$LocSh.job.id == 'blockade_spl_esc_m' or @$LocSh.job.id == 'blockade_spl_esc_s'
						                or @$LocSh.job.id == 'blockade_ter_esc_m' or @$LocSh.job.id == 'blockade_ter_esc_s'
						                or @$LocSh.job.id == 'blockade_bor_esc_m' or @$LocSh.job.id == 'blockade_bor_esc_s')
						              and (not @$LocSh.commander.exists)">

							<!-- Orphan. Hunt for a surviving leader in the same cluster. -->
							<set_value name="$LocNewLeader" exact="null"/>
							<do_for_each name="$LocClSect" in="$LocSh.sector.cluster.sectors">
								<do_if value="$LocNewLeader == null">
									<find_ship name="$LocClShips" space="$LocClSect" multiple="true" faction="$LocFaction"/>
									<do_for_each name="$LocCSh" in="$LocClShips">
										<do_if value="$LocNewLeader == null
										              and $LocCSh.exists
										              and @$LocCSh.job
										              and ($LocLeaderJobIds.indexof.{$LocCSh.job.id} gt 0)">
											<set_value name="$LocNewLeader" exact="$LocCSh"/>
										</do_if>
									</do_for_each>
									<remove_value name="$LocClShips"/>
								</do_if>
							</do_for_each>

							<do_if value="$LocNewLeader">
								<!-- Re-attach. Subgroup 1 for M escorts, 2 for S escorts.
								     Then cancel the (invalid-target) Escort order; default
								     Escort re-fires picking up the new commander. -->
								<set_value name="$LocSubgroup" exact="if $LocSh.isclass.ship_s then 2 else 1"/>
								<set_object_commander object="$LocSh" commander="$LocNewLeader" subordinategroupid="$LocSubgroup"/>
								<do_if value="@$LocSh.order">
									<cancel_order order="$LocSh.order"/>
								</do_if>
								<debug_text text="'BB: orphan %s re-attached to %s in %s.'.[$LocSh.knownname, $LocNewLeader.knownname, $LocSh.sector.cluster.knownname]" filter="general"/>
							</do_if>
							<do_else>
								<!-- No surviving leader in cluster. Send to nearest
								     faction shipyard via MoveWait. Ship lives, becomes
								     idle but reachable. -->
								<find_station_by_true_owner name="$LocSY" faction="$LocFaction" space="player.galaxy" canbuildships="true"/>
								<do_if value="$LocSY">
									<create_order id="'MoveWait'" object="$LocSh" immediate="true">
										<param name="destination" value="[$LocSY.sector, $LocSY]"/>
										<param name="recallsubordinates" value="false"/>
									</create_order>
									<debug_text text="'BB: orphan %s sent to shipyard %s (no leader in %s).'.[$LocSh.knownname, $LocSY.knownname, $LocSh.sector.cluster.knownname]" filter="general"/>
								</do_if>
								<remove_value name="$LocSY"/>
							</do_else>

							<remove_value name="$LocNewLeader"/>
							<remove_value name="$LocSubgroup"/>
						</do_if>
					</do_for_each>
					<remove_value name="$LocShips"/>
				</do_for_each>

				<remove_value name="$LocFactions"/>
				<remove_value name="$LocLeaderJobIds"/>
			</actions>
		</cue>

	</cues>
</mdscript>
