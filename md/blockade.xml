<?xml version="1.0" encoding="utf-8" ?>
<mdscript name="Blockade" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="md.xsd">
	<!--
		AI deployment lives in libraries/jobs.xml now — X4's faction economy
		builds the blockade leader + escorts at its shipyards over real time,
		spawned via the job system rather than create_ship.

		This MD file now only holds the persistent state table for any future
		tunables (NewsEnabled, DebugDetailed). The scan/dispatch/maintenance
		cues that previously spawned fleets directly were removed when the
		jobs-based system replaced them. Legacy save data in $ActiveBlockades
		etc. is harmless — it just sits unused.

		State table: md.$BBVarTable, aliased as $BBVT.
			$NewsEnabled          bool   (reserved; logbook entries not currently fired)
			$DebugDetailed        bool   (reserved)
	-->

	<cues>

		<cue name="Init">
			<conditions>
				<event_game_started/>
			</conditions>
			<actions>
				<set_value name="md.$BBVarTable" exact="table[]"/>
				<signal_cue_instantly cue="VerifyVariables"/>
			</actions>
		</cue>

		<cue name="OnLoad" instantiate="true">
			<conditions>
				<event_game_loaded/>
			</conditions>
			<actions>
				<do_if value="(not md.$BBVarTable?) or (md.$BBVarTable == null)">
					<set_value name="md.$BBVarTable" exact="table[]"/>
				</do_if>
				<signal_cue_instantly cue="VerifyVariables"/>
			</actions>
		</cue>

		<cue name="VerifyVariables" instantiate="true">
			<conditions>
				<event_cue_signalled/>
			</conditions>
			<actions>
				<set_value name="$BBVT" exact="md.$BBVarTable"/>
				<do_if value="not $BBVT.$DebugDetailed?">
					<set_value name="$BBVT.$DebugDetailed" exact="false"/>
				</do_if>
				<do_if value="not $BBVT.$NewsEnabled?">
					<set_value name="$BBVT.$NewsEnabled" exact="true"/>
				</do_if>
			</actions>
		</cue>

	</cues>
</mdscript>
