<?xml version="1.0" encoding="utf-8" ?>
<aiscript name="order.move.blockade" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="aiscripts.xsd" version="1">
  <order id="Blockade" name="{20810, 100}" description="{20810, 101}" category="combat" allowinloop="false">
    <params>
      <param name="target" type="object" text="{20810, 110}" comment="Gate to blockade.">
        <input_param name="class" value="class.gate"/>
      </param>
      <param name="distance" type="length" default="6km" text="{20810, 111}" comment="Distance from gate (sphere radius).">
        <input_param name="min" value="3km"/>
        <input_param name="max" value="20km"/>
        <input_param name="step" value="1km"/>
      </param>
      <param name="engagerange" type="length" default="this.ship.maxradarrange" text="{20810, 112}" comment="Engage hostiles within this range.">
        <input_param name="min" value="3km"/>
        <input_param name="max" value="[this.ship.maxradarrange, 3km].max"/>
        <input_param name="step" value="1km"/>
      </param>
      <param name="pursuetargets" default="false" type="bool" text="{20810, 113}" advanced="true" comment="Pursue hostiles beyond the blockade ring."/>
      <param name="attackonsight" default="true" type="bool" text="{20810, 114}" advanced="true" comment="Attack hostiles on sight (vs. only when attacked)."/>
      <param name="hostileside" default="0" type="internal" comment="Which side of the gate: 0=auto, 1=destination-facing, -1=interior-facing."/>
      <param name="lookaway" default="false" type="bool" text="{20810, 118}" comment="Face away from the gate (sector-side blockade) instead of toward it."/>
      <param name="formationsize" default="0" type="internal" comment="Total ships in formation. 0 = auto-detect from fleet."/>
      <param name="slotindex" default="-1" type="internal" comment="This ship's slot in the formation. -1 = auto-detect."/>
      <param name="slotpos" default="null" type="internal" comment="Computed slot position in $targetsector. Set in init; exposed via &lt;location&gt; so the map can render the per-ship destination."/>
      <param name="timeout" type="time" default="0s" infinitevalue="0s" text="{1041, 10034}" advanced="true" comment="Duration (0 = infinite).">
        <input_param name="max" value="1h"/>
        <input_param name="step" value="30s"/>
      </param>
      <param name="objectstoignore" default="[]" type="internal" comment="List of objects to be ignored"/>
      <param name="debugchance" type="bool" default="0" advanced="true" text="{1041, 10086}" comment="Print debug output">
        <input_param name="truevalue" value="100"/>
      </param>
    </params>
    <requires>
      <match shiptype="shiptype.lasertower" negate="true"/>
      <match class="class.spacesuit" negate="true"/>
    </requires>
    <!-- Two-tier location: prefer the slot position (per-ship marker, drawn like
         move.generic does); fall back to the gate itself if init hasn't computed
         the slot yet (e.g. order is queued but hasn't run). -->
    <location object="$targetsector" position="$slotpos" condition="$targetsector and $slotpos"/>
    <location object="$target" condition="$target"/>
  </order>
  <interrupts>
    <handler ref="InterruptAttack"/>
    <handler ref="SectorChangeHandler"/>
    <handler ref="ScannedHandler"/>
    <handler ref="InspectedHandler"/>
    <handler ref="TargetInvalidHandler"/>
    <handler ref="TideHandler"/>
    <handler>
      <conditions>
        <check_any>
          <event_object_destroyed object="$target" check="false"/>
          <event_object_changed_true_owner object="$target" check="false"/>
        </check_any>
      </conditions>
      <actions>
        <debug_text text="'blockade target gate %s no longer valid; finishing.'.[@$target.knownname]" chance="$debugchance"/>
        <abort_called_scripts resume="finish"/>
      </actions>
    </handler>
  </interrupts>
  <init>
    <!-- command.blockade doesn't exist in the engine enum (hardcoded list,
         not mod-extendable). command.protect with the gate's destination
         sector as the param shows "Beschütze <hostile sector>" /
         "Protecting <hostile sector>" — the actual destination name
         rather than the generic gate knownname ("Sprunggate" for every
         gate in the game, useless to the player). Slightly off
         semantically (the ship is blockading the gate FROM that sector,
         not protecting it) but the destination name is the only useful
         per-ship signal in the UI. Fall back to the gate itself if the
         destination chain is null (gate destroyed mid-order). -->
    <do_if value="@$target.destination.sector">
      <set_command command="command.protect" param="$target.destination.sector"/>
    </do_if>
    <do_else>
      <set_command command="command.protect" param="$target"/>
    </do_else>

    <!-- Auto-pick target gate when none was passed in (job-spawned ships
         can't bake a specific gate into the job XML; vanilla job <order>
         params only take static enums). Look at this ship's current
         sector for an active gate whose destination owner is hostile to
         the ship's owner — same hostile-pair test the MD scan used. If
         multiple, the first match wins; the job's per-cluster quota
         keeps deployment density reasonable. -->
    <do_if value="(not $target or not $target.exists or not $target.isclass.gate) and this.ship.sector">
      <find_gate name="$LocAutoGates" space="this.ship.sector" active="true" multiple="true"/>
      <do_for_each name="$LocAutoG" in="$LocAutoGates">
        <do_if value="(not $target) and $LocAutoG.exists and $LocAutoG.destination.exists
                      and @$LocAutoG.destination.sector.owner
                      and ($LocAutoG.destination.sector.owner != this.assignedcontrolled.owner)
                      and this.assignedcontrolled.owner.mayattack.{$LocAutoG.destination.sector.owner}
                      and (this.assignedcontrolled.owner.relationto.{$LocAutoG.destination.sector.owner} le -0.25)">
          <set_value name="$target" exact="$LocAutoG"/>
          <debug_text text="'Blockade: auto-picked gate %s in %s.'.[$target.knownname, this.ship.sector.knownname]" chance="$debugchance"/>
        </do_if>
      </do_for_each>
      <remove_value name="$LocAutoGates"/>
    </do_if>

    <!-- Validate target -->
    <do_if value="not $target or not $target.exists or not $target.isclass.gate">
      <debug_text text="'Blockade: invalid target. Aborting.'" filter="error"/>
      <set_value name="$abort"/>
    </do_if>

    <!-- "Already blockaded" check. Use @chain.field safe-read — vanilla pattern.
         @$X.order.id propagates null through the whole chain, so null == 'Blockade'
         is just false (no parser/runtime error). Earlier attempts using $X.order?
         failed because ? checks schema-definedness, not value-non-null, and the
         engine evaluates every conjunct in an AND chain regardless. -->
    <do_if value="not $abort?">
      <find_ship name="$LocSectorShips" space="$target.sector" multiple="true"/>
      <do_for_each name="$LocOtherShip" in="$LocSectorShips">
        <do_if value="not $abort?
                      and ($LocOtherShip != this.assignedcontrolled)
                      and ($LocOtherShip.owner != this.assignedcontrolled.owner)
                      and (@$LocOtherShip.order.id == 'Blockade')
                      and ($LocOtherShip.distanceto.{$target} lt 25km)">
          <debug_text text="'Blockade: %s already blockaded by %s; aborting.'.[$target.knownname, $LocOtherShip.owner.name]" chance="$debugchance"/>
          <!-- set_order_failed needs the order to be the ship's *current* order,
               which it isn't during init for dispatched subs. Skip the failure
               status and just flag $abort; the actions block resumes finish. -->
          <set_value name="$abort"/>
        </do_if>
      </do_for_each>
    </do_if>

    <!-- Resolve sector. Gates live in a zone inside a sector. -->
    <do_if value="not $abort?">
      <set_value name="$targetsector" exact="$target.sector"/>
      <do_if value="not $targetsector">
        <debug_text text="'Blockade: target gate has no sector. Aborting.'" filter="error"/>
        <set_value name="$abort"/>
      </do_if>
    </do_if>

    <!-- Determine hostile-side sign. Vanilla deploys at z=-3km for accelerators and
         z=+3km for jumpgates (see order.deployobjectsatgates.xml); we follow the
         same convention so the formation lands on the "incoming traffic" side. -->
    <do_if value="not $abort?">
      <do_if value="$hostileside == 1">
        <set_value name="$zsign" exact="1.0f"/>
      </do_if>
      <do_elseif value="$hostileside == -1">
        <set_value name="$zsign" exact="-1.0f"/>
      </do_elseif>
      <do_else>
        <do_if value="$target.isaccelerator">
          <set_value name="$zsign" exact="-1.0f"/>
        </do_if>
        <do_else>
          <set_value name="$zsign" exact="1.0f"/>
        </do_else>
      </do_else>
    </do_if>

    <!-- Resolve own slot. Leader/solo: 0. Explicit override from MD dispatch
         path: trust it. Subs of a leader never run Blockade — they run vanilla
         MoveWait dispatched from below. -->
    <do_if value="not $abort?">
      <set_value name="$resolvedsize" exact="$formationsize"/>
      <set_value name="$resolvedslot" exact="$slotindex"/>
      <do_if value="$resolvedslot lt 0">
        <set_value name="$resolvedslot" exact="0"/>
      </do_if>

      <!-- If we're a wing leader, sort subs L/XL → M → S/everything-else so the
           bigger ships fill the inner hemisphere rings (closer to the gate) and
           smaller fast-engaging ships sit on the outer rings. Then dispatch each
           a vanilla MoveWait order at its slot — they fly there, face the gate,
           and hold. Vanilla's MoveWait + its built-in InterruptAttack handling
           gives us "sit until attacked, engage via vanilla combat, return to
           slot when clear" without any of our own scan/dispatch logic. -->
      <do_if value="this.assignedcontrolled.subordinates.count gt 0">
        <set_value name="$resolvedsize" exact="this.assignedcontrolled.subordinates.count + 1"/>

        <set_value name="$orderedsubs" exact="[]"/>
        <do_for_each name="$LocSub" in="this.assignedcontrolled.subordinates">
          <do_if value="$LocSub.isclass.ship_l or $LocSub.isclass.ship_xl">
            <append_to_list name="$orderedsubs" exact="$LocSub"/>
          </do_if>
        </do_for_each>
        <do_for_each name="$LocSub" in="this.assignedcontrolled.subordinates">
          <do_if value="$LocSub.isclass.ship_m">
            <append_to_list name="$orderedsubs" exact="$LocSub"/>
          </do_if>
        </do_for_each>
        <do_for_each name="$LocSub" in="this.assignedcontrolled.subordinates">
          <do_if value="not ($LocSub.isclass.ship_l or $LocSub.isclass.ship_xl or $LocSub.isclass.ship_m)">
            <append_to_list name="$orderedsubs" exact="$LocSub"/>
          </do_if>
        </do_for_each>

        <set_value name="$dispidx" exact="1"/>
        <do_for_each name="$LocSub" in="$orderedsubs">
          <!-- Slot geometry per dispidx (same hemisphere model as before). -->
          <do_if value="$dispidx le 6">
            <set_value name="$LocTheta" exact="30deg"/>
            <set_value name="$LocPhi" exact="($dispidx - 1) * 2.0f * pi / 6.0f"/>
          </do_if>
          <do_elseif value="$dispidx le 12">
            <set_value name="$LocTheta" exact="60deg"/>
            <set_value name="$LocPhi" exact="($dispidx - 7) * 2.0f * pi / 6.0f"/>
          </do_elseif>
          <do_else>
            <set_value name="$LocTheta" exact="80deg"/>
            <set_value name="$LocPhi" exact="($dispidx - 13) * 2.0f * pi / 8.0f"/>
          </do_else>

          <set_value name="$LocEffd" exact="$distance + $LocSub.size"/>
          <set_value name="$LocSx" exact="$LocEffd * sin($LocTheta) * cos($LocPhi)"/>
          <set_value name="$LocSy" exact="$LocEffd * sin($LocTheta) * sin($LocPhi)"/>
          <set_value name="$LocSz" exact="$zsign * $LocEffd * cos($LocTheta)"/>

          <create_position name="$LocSubSlot" space="$targetsector"
                           x="$LocSx" y="$LocSy" z="$LocSz" object="$target"/>

          <!-- Lookat: doubled offset (away from gate) for $lookaway, gate itself otherwise. -->
          <do_if value="$lookaway">
            <create_position name="$LocLookatPos" space="$targetsector"
                             x="$LocSx * 2.0f" y="$LocSy * 2.0f" z="$LocSz * 2.0f" object="$target"/>
          </do_if>
          <do_else>
            <create_position name="$LocLookatPos" space="$targetsector" object="$target"/>
          </do_else>

          <!-- Clear stale orders from any prior dispatch. Must cancel BOTH
               the current active AND the default — otherwise:
                 - old active still queues behind our new immediate one and
                   the sub flies new-slot → old-slot once arrival completes
                 - old default is what the sub falls back to after the new
                   active finishes, dragging it to the previous gate
               Cover MoveWait/ProtectPosition/AttackInRange/Blockade so
               retargeting works regardless of which mode we were in. -->
          <do_if value="@$LocSub.order.id == 'MoveWait'
                        or @$LocSub.order.id == 'ProtectPosition'
                        or @$LocSub.order.id == 'AttackInRange'
                        or @$LocSub.order.id == 'Blockade'">
            <cancel_order order="$LocSub.order"/>
          </do_if>
          <do_if value="@$LocSub.defaultorder.id == 'MoveWait'
                        or @$LocSub.defaultorder.id == 'ProtectPosition'
                        or @$LocSub.defaultorder.id == 'AttackInRange'
                        or @$LocSub.defaultorder.id == 'Blockade'">
            <cancel_order order="$LocSub.defaultorder"/>
          </do_if>

          <!-- MoveWait positioned ships correctly in testing; ProtectPosition's
               internal activepatrol scatters them. Subs run MoveWait at their
               slot (vanilla position-and-hold). Proactive engagement comes from
               the leader's hold loop below, which scans and dispatches
               AttackInRange to subs when hostiles enter the gate area; subs
               engage, then fall back to MoveWait default and return to slot. -->
          <!-- default="true" MoveWait does NOT accept the timeout param —
               engine throws "Timeout parameter 'timeout' was not expected for
               default order" and the whole order spams errors. Only the active
               variant below takes timeout. -->
          <create_order id="'MoveWait'" object="$LocSub" default="true">
            <param name="destination" value="[$targetsector, $LocSubSlot]"/>
            <param name="lookat" value="$LocLookatPos"/>
            <param name="recallsubordinates" value="false"/>
            <param name="debugchance" value="$debugchance"/>
          </create_order>
          <!-- Omit default attribute entirely on active orders. X4 treats
               default="false" as still flagging this as a default-style
               order and silently ignores immediate="true". -->
          <create_order id="'MoveWait'" object="$LocSub" immediate="true">
            <param name="destination" value="[$targetsector, $LocSubSlot]"/>
            <param name="lookat" value="$LocLookatPos"/>
            <param name="timeout" value="0s"/>
            <param name="recallsubordinates" value="false"/>
            <param name="debugchance" value="$debugchance"/>
          </create_order>

          <set_value name="$dispidx" operation="add" exact="1"/>
          <remove_value name="$LocSubSlot"/>
          <remove_value name="$LocLookatPos"/>
        </do_for_each>

        <remove_value name="$orderedsubs"/>
      </do_if>

      <do_if value="$resolvedsize le 0">
        <set_value name="$resolvedsize" exact="$resolvedslot + 1"/>
      </do_if>
    </do_if>

    <!-- Compute slot coordinates in the gate's local frame.
         Hemisphere layout:
           slot 0          → center (theta=0,  directly in front; leader)
           slots 1..6      → inner ring (theta=30°)
           slots 7..12     → outer ring (theta=60°)
           slots 13+       → flat ring (theta=80°)
         theta is the polar angle from the gate's +Z (hostile-side) axis.

         Slot 0 sits on the gate's z-axis, which is exactly the highway
         centerline mass traffic flows along. XL/L ships then fight pathing
         and collision avoidance against transiting NPCs and can never reach
         the slot. Offset slot 0 perpendicular to the highway (+y, "above"
         the gate plane) by ~2km plus the ship's own size so larger hulls
         get more clearance. Rings 1+ already sit off-axis (sin θ ≠ 0) so
         they don't need this. -->
    <do_if value="not $abort?">
      <do_if value="$resolvedslot == 0">
        <set_value name="$theta" exact="0.0f"/>
        <set_value name="$phi" exact="0.0f"/>
      </do_if>
      <do_elseif value="$resolvedslot le 6">
        <set_value name="$theta" exact="30deg"/>
        <set_value name="$phi" exact="($resolvedslot - 1) * 2.0f * pi / 6.0f"/>
      </do_elseif>
      <do_elseif value="$resolvedslot le 12">
        <set_value name="$theta" exact="60deg"/>
        <set_value name="$phi" exact="($resolvedslot - 7) * 2.0f * pi / 6.0f"/>
      </do_elseif>
      <do_else>
        <set_value name="$theta" exact="80deg"/>
        <set_value name="$phi" exact="($resolvedslot - 13) * 2.0f * pi / 8.0f"/>
      </do_else>

      <!-- Scale effective distance by ship size so XL/L ships sit further out and
           don't fight collision avoidance trying to share a slot with the gate or
           with each other. this.ship.size returns a length in metres. -->
      <set_value name="$effdistance" exact="$distance + this.ship.size"/>

      <set_value name="$slotx" exact="$effdistance * sin($theta) * cos($phi)"/>
      <set_value name="$sloty" exact="$effdistance * sin($theta) * sin($phi)"/>
      <set_value name="$slotz" exact="$zsign * $effdistance * cos($theta)"/>

      <!-- Highway-clearance offset for leader (slot 0 only). Push 2km + size
           in +y so the leader sits above the highway centerline. -->
      <do_if value="$resolvedslot == 0">
        <set_value name="$sloty" exact="2km + this.ship.size"/>
      </do_if>

      <create_position name="$slotpos" space="$targetsector"
                       x="$slotx" y="$sloty" z="$slotz"
                       object="$target"/>

      <!-- Slot-arrival tolerance scaled by ship size. move.generic with
           playerprecise=true still picks a safepos near $slotpos (not the
           exact point) so $arrivaltol has to be lenient enough to count
           that safepos as "arrived" — otherwise the in-transit branch
           re-fires move.generic, lands at the same safepos again,
           re-fires, etc. Hysteresis: enter at-slot at $arrivaltol, only
           exit when knocked beyond $exittol. -->
      <set_value name="$arrivaltol" exact="[1.5km, this.ship.size * 3.0f].max"/>
      <set_value name="$exittol" exact="$arrivaltol * 2.0f"/>

      <debug_text text="'Blockade: gate %s, slot %s/%s (size=%sm, effd=%sm, arrivaltol=%sm), theta=%sdeg phi=%sdeg, pos=%s'.[$target.knownname, $resolvedslot, $resolvedsize, this.ship.size, $effdistance, $arrivaltol, $theta / 1deg, $phi / 1deg, $slotpos]" chance="$debugchance"/>
    </do_if>

    <!-- Leader weapon-mode override: bastion-style leader sits at slot and
         doesn't actively chase, but its weapons should fire at any enemy
         that wanders into range. Default weaponmode.defend only returns
         fire when attacked — too passive for a blockade. Flip everything
         to weaponmode.attackenemies and stash the previous mode per-weapon
         in $weaponmodebackup so finish/on_abort can restore exactly.
         Preserve missiledefence and mining assignments so per-turret
         roles like anti-missile coverage aren't trampled. Direct
         <set_weapon_mode> calls (bypass lib.set.weaponmode) — the lib
         wrapper was leaving modes unchanged for some weapon classes. -->
    <do_if value="not $abort?">
      <find_object_component name="$LocAllWeapons" object="this.assignedcontrolled" weapontype="combat" multiple="true"/>
      <set_value name="$weaponmodebackup" exact="table[]"/>
      <do_for_each name="$LocW" in="$LocAllWeapons">
        <set_value name="$weaponmodebackup.{$LocW}" exact="$LocW.mode"/>
        <do_if value="$LocW.mode != weaponmode.missiledefence and $LocW.mode != weaponmode.mining">
          <set_weapon_mode weapon="$LocW" weaponmode="weaponmode.attackenemies"/>
        </do_if>
      </do_for_each>
      <debug_text text="'Blockade: leader weapons set, %s weapons captured (%s switched to attackenemies).'.[$LocAllWeapons.count, $weaponmodebackup.keys.count]" chance="$debugchance"/>
      <remove_value name="$LocAllWeapons"/>
    </do_if>

    <set_value name="$inittime" exact="player.age"/>
  </init>
  <attention min="unknown">
    <actions>
      <do_if value="$abort?">
        <resume label="finish"/>
      </do_if>

      <label name="start"/>

      <!-- Architecture (vanilla-aligned per md_9.0_gotchas + agent analysis
           of order.move.wait.xml / order.fight.protect.position.xml):

           1. Run move.generic ONCE here, before the hold loop. Polling
              move.generic on every loop iteration was the "circling" bug
              — each call re-evaluates safepos, the engine engages thrust
              to "start" the move, then realizes it's already there. The
              ship visibly wobbles. Sub dispatches via vanilla MoveWait
              work cleanly because MoveWait calls move.generic exactly
              once per dispatch.

           2. After arrival: stop_moving + stop_boost + standingby + one-
              shot set_order_syncpoint_reached, mirroring the MoveWait
              tail (order.move.wait.xml:283-301).

           3. Then enter the hold loop which is pure scan/dispatch +
              rotation refinement. NO move.generic re-fires unless drift
              exceeds $exittol (a re-transit), in which case we resume
              to label start and rerun this whole block.

           Defaults match vanilla MoveWait: precise/playerprecise omitted
           (both default false). The earlier playerprecise=true degraded
           large-hull safepos selection. -->

      <do_if value="not $target.exists or not $target.isclass.gate">
        <resume label="finish"/>
      </do_if>

      <do_if value="$lookaway">
        <create_position name="$LocLeaderLookat" space="$targetsector" object="this.ship"/>
      </do_if>
      <do_else>
        <create_position name="$LocLeaderLookat" space="$targetsector" object="$target"/>
      </do_else>

      <set_command_action commandaction="commandaction.flyingto" param="$target"/>
      <run_script name="'move.generic'" result="$movesuccess">
        <param name="destination" value="$targetsector"/>
        <param name="position" value="$slotpos"/>
        <param name="lookat" value="$LocLeaderLookat"/>
        <param name="recallsubordinates" value="false"/>
        <param name="debugchance" value="$debugchance"/>
      </run_script>
      <stop_moving object="this.ship"/>
      <stop_boost object="this.ship"/>
      <set_command command="command.wait"/>
      <set_command_action commandaction="commandaction.standingby"/>
      <remove_value name="$LocLeaderLookat"/>

      <do_if value="not $synced?">
        <set_order_syncpoint_reached order="this.ship.order"/>
        <set_value name="$synced" exact="true"/>
      </do_if>

      <!-- Hold loop: scan + dispatch + rotation refinement only. No
           movement re-fires. Drift check at the bottom; if knocked
           materially off slot, resume to start and re-run move.generic. -->
      <do_while value="$target.exists">
        <do_if value="not $target.exists or not $target.isclass.gate">
          <resume label="finish"/>
        </do_if>
        <do_if value="$timeout and (player.age ge $inittime + $timeout)">
          <resume label="finish"/>
        </do_if>
        <!-- Hostility reality-check. The order was launched against a
             hostile destination, but state can shift mid-blockade: the
             destination sector flipped to our own faction (war won),
             the destination owner flipped to a friendly faction (war
             ended), or the destination simply became friendly via
             Dynamic War / diplomacy. In any of those, the blockade no
             longer makes sense — finish cleanly so the job system can
             re-task the ship to a current hostile-facing gate. -->
        <do_if value="not @$target.destination.exists
                      or not @$target.destination.sector.owner
                      or ($target.destination.sector.owner == this.assignedcontrolled.owner)
                      or (not this.assignedcontrolled.owner.mayattack.{$target.destination.sector.owner})
                      or (this.assignedcontrolled.owner.relationto.{$target.destination.sector.owner} gt -0.1)">
          <debug_text text="'Blockade: %s — target no longer hostile, finishing (dest=%s, dest.owner=%s).'.[$target.knownname, @$target.destination, @$target.destination.sector.owner]" filter="general"/>
          <resume label="finish"/>
        </do_if>

        <!-- Two-tier scan + dispatch (gate vicinity → leader vicinity).
             Rally destination = leader's current position so subs converge
             on the actual fight. -->
        <do_if value="this.assignedcontrolled.subordinates.count gt 0">
          <set_value name="$LocBlockadeHostile" exact="null"/>
          <find_object name="$LocBlockadeHostile"
                       object="$target"
                       space="$targetsector"
                       max="$engagerange"
                       relation="enemy"
                       class="class.ship"
                       multiple="false"/>
          <do_if value="not $LocBlockadeHostile">
            <find_object name="$LocBlockadeHostile"
                         object="this.assignedcontrolled"
                         space="$targetsector"
                         max="$engagerange"
                         relation="enemy"
                         class="class.ship"
                         multiple="false"/>
          </do_if>
          <do_if value="$LocBlockadeHostile">
            <create_position name="$LocRallyPos" space="$targetsector" object="this.assignedcontrolled"/>
            <debug_text text="'Blockade: hostile %s detected, dispatching subs to leader pos.'.[$LocBlockadeHostile.knownname]" chance="$debugchance"/>
            <do_for_each name="$LocSub" in="this.assignedcontrolled.subordinates">
              <do_if value="@$LocSub.order.id == 'MoveWait'">
                <create_order id="'AttackInRange'" object="$LocSub" immediate="true">
                  <param name="destination" value="[$targetsector, $LocRallyPos]"/>
                  <param name="radius" value="$engagerange"/>
                  <param name="pursuetargets" value="$pursuetargets"/>
                  <param name="enforceradius" value="true"/>
                  <param name="debugchance" value="$debugchance"/>
                </create_order>
              </do_if>
            </do_for_each>
            <remove_value name="$LocRallyPos"/>
          </do_if>
        </do_if>

        <!-- Rotation-only refinement at slot. forceposition=true + current
             ship position pins translation; forcerotation=true converges
             facing on $LocFaceRot. Short interrupt so the next scan
             iteration fires promptly. -->
        <do_if value="$lookaway">
          <create_orientation name="$LocFaceRot" orientation="look_away" refobject="$target">
            <position object="this.ship"/>
          </create_orientation>
        </do_if>
        <do_else>
          <create_orientation name="$LocFaceRot" orientation="look_at" refobject="$target">
            <position object="this.ship"/>
          </create_orientation>
        </do_else>
        <move_to object="this.ship" destination="$targetsector"
                 forcerotation="true" forceposition="true" commandaction="false">
          <position object="this.ship"/>
          <rotation value="$LocFaceRot"/>
          <interrupt_after_time time="3s"/>
        </move_to>
        <remove_value name="$LocFaceRot"/>

        <!-- Drift detection — only re-transit if ship was knocked WAY off
             slot (weapon impulse, mass-traffic shove). $exittol is the
             generous threshold from init. Smaller drift accepted. -->
        <set_value name="$slotdist" exact="this.ship.distanceto.[$targetsector, $slotpos]"/>
        <do_if value="$slotdist gt $exittol">
          <debug_text text="'Blockade: drifted %sm off slot (>%sm), re-transit.'.[($slotdist)i, ($exittol)i]" chance="$debugchance"/>
          <resume label="start"/>
        </do_if>

        <wait min="10s" max="20s"/>
      </do_while>

      <label name="finish"/>

      <!-- Release each sub: cancel their active MoveWait, then cancel the default
           MoveWait we set in init — otherwise the sub falls back to MoveWait
           default and stays stuck at the slot. Pattern from vanilla scripts that
           cancel_order on $ship.defaultorder. -->
      <do_if value="this.assignedcontrolled.subordinates.count gt 0">
        <do_for_each name="$LocSub" in="this.assignedcontrolled.subordinates">
          <do_if value="@$LocSub.order.id == 'MoveWait' or @$LocSub.order.id == 'AttackInRange'">
            <cancel_order order="$LocSub.order"/>
          </do_if>
          <do_if value="@$LocSub.defaultorder.id == 'MoveWait'">
            <cancel_order order="$LocSub.defaultorder"/>
          </do_if>
        </do_for_each>
      </do_if>

      <!-- Restore leader weapon modes to whatever was set pre-blockade.
           $weaponmodebackup is a table[weapon -> mode]; replay each entry. -->
      <do_if value="$weaponmodebackup? and ($weaponmodebackup.keys.count gt 0)">
        <do_for_each name="$LocRW" in="$weaponmodebackup.keys.list">
          <do_if value="$LocRW.exists">
            <set_weapon_mode weapon="$LocRW" weaponmode="$weaponmodebackup.{$LocRW}"/>
          </do_if>
        </do_for_each>
      </do_if>
    </actions>
  </attention>
  <!-- Runs when the script is aborted externally (player cancels/replaces the
       order). Mirrors the finish-label cleanup. -->
  <on_abort>
    <do_if value="this.assignedcontrolled.subordinates.count gt 0">
      <do_for_each name="$LocSub" in="this.assignedcontrolled.subordinates">
        <do_if value="@$LocSub.order.id == 'MoveWait' or @$LocSub.order.id == 'AttackInRange'">
          <cancel_order order="$LocSub.order"/>
        </do_if>
        <do_if value="@$LocSub.defaultorder.id == 'MoveWait'">
          <cancel_order order="$LocSub.defaultorder"/>
        </do_if>
      </do_for_each>
    </do_if>
    <do_if value="$weaponmodebackup? and ($weaponmodebackup.keys.count gt 0)">
      <do_for_each name="$LocRW" in="$weaponmodebackup.keys.list">
        <do_if value="$LocRW.exists">
          <set_weapon_mode weapon="$LocRW" weaponmode="$weaponmodebackup.{$LocRW}"/>
        </do_if>
      </do_for_each>
    </do_if>
  </on_abort>
</aiscript>
